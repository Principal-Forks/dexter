{
  "id": "dexter-onboarding",
  "title": "Dexter: AI Financial Research Agent",
  "description": "A guided tour of Dexter's architecture — from entry point to autonomous agent, tools, memory, skills, and gateway.",
  "version": "1.0.0",
  "audience": "New Contributors & AI Assistants",
  "prerequisites": [
    "Basic TypeScript knowledge",
    "Familiarity with LLM agent concepts"
  ],
  "steps": [
    {
      "id": "step-1-overview",
      "title": "Welcome to Dexter",
      "description": "Dexter is an autonomous financial research agent that decomposes complex financial questions into research plans, executes them with real-time market data, and self-validates results. Built with Bun, LangChain, and a terminal UI.",
      "estimatedTime": 30,
      "focusDirectory": "",
      "colorMode": "fileTypes",
      "interactiveActions": [
        {
          "type": "explore",
          "description": "Take a moment to explore the full codebase layout"
        }
      ]
    },
    {
      "id": "step-2-entry-point",
      "title": "Entry Point & CLI",
      "description": "The application bootstraps a terminal UI from its main entry point. Separate modules handle command-line argument parsing and configure the available LLM providers — OpenAI, Anthropic, Google, Ollama, and more.",
      "estimatedTime": 45,
      "focusDirectory": "src",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "entry-files",
          "name": "Entry Point Files",
          "color": "#3b82f6",
          "items": [
            { "path": "src/index.tsx", "type": "file" },
            { "path": "src/cli.ts", "type": "file" },
            { "path": "src/providers.ts", "type": "file" },
            { "path": "src/theme.ts", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "fill"
        }
      ],
      "interactiveActions": [
        {
          "type": "click-file",
          "description": "Click the main entry point to see how the app bootstraps",
          "target": "src/index.tsx"
        }
      ]
    },
    {
